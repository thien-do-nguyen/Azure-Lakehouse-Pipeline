# =============================================================================
# Hybrid Azure environment (PostgreSQL + ADLS Gen2 in cloud, Spark local)
# =============================================================================

# --- Azure Database for PostgreSQL Flexible Server ---
AZURE_POSTGRES_HOST=your-server.postgres.database.azure.com
AZURE_POSTGRES_PORT=5432
AZURE_POSTGRES_DB=ecommerce
AZURE_POSTGRES_USER=postgres
AZURE_POSTGRES_PASSWORD=<from-key-vault-or-set-here>

# --- Azure Data Lake Storage Gen2 ---
AZURE_STORAGE_ACCOUNT=yourstorageaccount
AZURE_CONTAINER=lakehouse
AZURE_STORAGE_AUTH_TYPE=account_key
AZURE_STORAGE_ACCOUNT_KEY=<from-key-vault-or-set-here>

# =============================================================================
# Optional fully local mode only (CONFIG=configs/local.yaml)
# =============================================================================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ecommerce
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin

